{
  "manifest_version": 3,
  "name": "PhishNova AI",
  "version": "1.0",
  "description": "ML + GPT Hybrid Phishing Detection for Gmail",
  "permissions": [
    "activeTab", 
    "scripting",
    "storage"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": "assets/icon48.png"
  },
  "icons": {
    "16": "assets/icon48.png",
    "48": "assets/icon48.png",
    "128": "assets/icon48.png"
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://mail.google.com/*",
    "http://127.0.0.1:5000/*",
    "https://phishguard-q77g.onrender.com/*"
  ]
}